[Desktop Entry]
Type=Application
Name=Chaos
Comment=Screensaver effect: chaos
Exec=env XCURSOR_PATH=/nonexistent XCURSOR_THEME=none xterm -fullscreen -bg black -fg white -ms black -xrm "XTerm*pointerColorBackground: black" -xrm "XTerm*pointerMode: 2" -e /usr/libexec/local76/screensavers/chaos
Icon=local76-chaos
Terminal=false
Categories=Screensaver;
